<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@drawable/background"
    android:layout_height="match_parent">



        <View
            android:id="@+id/idconponents"
            style="@style/ContainerComponents"
            android:layout_width="371dp"
            android:layout_height="541dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.363" />

        <ImageView
            android:id="@+id/serviceImage"
            android:layout_width="126dp"
            android:layout_height="140dp"
            android:layout_marginStart="144dp"
            android:layout_marginTop="84dp"
            android:src="@drawable/limpeza"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/serviceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="104dp"
            android:layout_marginTop="248dp"
            android:text="Limpeza no apartamento"
            android:textSize="20sp"
            android:textStyle="bold|italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/floorEditText"
            style="@style/Edit_text"
            android:layout_width="276dp"
            android:layout_height="58dp"
            android:ems="10"
            android:hint="Andar"
            android:inputType="text"
            android:textColor="#515151"
            android:textColorHighlight="#FFFFFF"
            android:textColorHint="#6E6E6E"
            app:circularflow_defaultRadius="20dp"
            app:circularflow_radiusInDP="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/serviceName"
            app:layout_constraintVertical_bias="0.1" />

        <EditText
            android:id="@+id/apartmentEditText"
            style="@style/Edit_text"
            android:layout_width="276dp"
            android:layout_height="58dp"
            android:ems="10"
            android:hint="Número do apartamento"
            android:inputType="text"
            android:textColor="#515151"
            android:textColorHighlight="#FFFFFF"
            android:textColorHint="#6E6E6E"
            app:circularflow_defaultRadius="20dp"
            app:circularflow_radiusInDP="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/floorEditText"
            app:layout_constraintVertical_bias="0.114" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/sendButton"
            style="@style/botao"
            android:layout_width="276dp"
            android:layout_height="58dp"
            android:text="Enviar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/apartmentEditText"
            app:layout_constraintVertical_bias="0.099" />

</androidx.constraintlayout.widget.ConstraintLayout>
